export type Status =
  | 'pending_manager_approval' | 'pending_code_merge'        // <-- new
  | 'pending_staging_ci' | 'pending_staging_cd'
  | 'pending_staging_signoff' | 'pending_prod_ci' | 'pending_prod_cd'
  | 'completed' | 'rejected';

export type Action =
  | 'APPROVE' | 'REJECT' | 'MERGED'                          // <-- new
  | 'RUN_STAGING_CI' | 'RUN_STAGING_CD'
  | 'GIVE_SIGNOFF' | 'RUN_PROD_CI' | 'RUN_PROD_CD';

export const TRANSITIONS: Record<Action, Transition> = {
  APPROVE: { from: 'pending_manager_approval', to: 'pending_code_merge', group: 'manager-approvers' }, // changed target
