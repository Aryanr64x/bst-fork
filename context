router.post('/gitlab/webhook', async (req, res) => {
  // 1. authenticate the webhook (GitLab sends the secret in this header)
  if (req.header('x-gitlab-token') !== webhookSecret) {
    res.status(401).json({ error: 'invalid token' });
    return;
  }

  const body = req.body;
  // 2. only react to an actual merge
  if (body.object_kind !== 'merge_request' || body.object_attributes?.action !== 'merge') {
    res.status(200).json({ ignored: true });   // 200 so GitLab doesn't retry
    return;
  }

  const mrUrl = body.object_attributes.url as string;
  const merger = body.user?.username ?? 'unknown';

  // 3. find the request waiting on this MR
  const request = await store.getByPrLink(mrUrl);
  if (!request) {
    res.status(200).json({ ignored: true, reason: 'no matching request' });
    return;
  }

  // 4. let the state machine decide — this gives us idempotency for free
  const result = checkTransition('MERGED', request.status as Status, 'system');
  if (!result.ok) {
    logger.info(`webhook ${mrUrl}: ${result.reason}`); // e.g. already past this state
    res.status(200).json({ ignored: true, reason: result.reason });
    return;
  }

  const updated = await store.applyTransition(request.id, result.to, {
    actor: merger, action: 'MERGED', fromStatus: request.status,
  });
  res.status(200).json({ ok: true, status: updated.status });

  notifier
    .notify(updated.apiRef, `MR merged for "${updated.title}"`,
      `${merger} merged the PR. Status is now ${updated.status}.`)
    .catch(err => logger.error(`Notification failed: ${err}`));
});
Two things worth pausing on. The actor: merger comes from the GitLab payload — so your audit trail records who really merged, sourced from GitLab, exactly the better-audit point from our earlier discussion. And the checkTransition call gives you idempotency: GitLab sometimes sends duplicate webhooks, but a second "merged" event finds the request already in pending_staging_ci, the from no longer matches, and it harmlessly no-ops with a 200. You didn't write any dedupe logic — the state machine guard is the dedupe.

