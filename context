ts
import { RootConfigService, LoggerService } from '@backstage/backend-plugin-api';
import { createTransport, Transporter } from 'nodemailer';

export class Mailer {
  private constructor(
    private readonly transporter: Transporter,
    private readonly from: string,
    private readonly logger: LoggerService,
  ) {}

  static fromConfig(config: RootConfigService, logger: LoggerService) {
    const smtp = config.getConfig('productionRequests.email.smtp');
    const transporter = createTransport({
      host: smtp.getString('host'),
      port: smtp.getNumber('port'),
      secure: smtp.getOptionalBoolean('secure') ?? false,
      auth: smtp.has('auth')
        ? { user: smtp.getString('auth.user'), pass: smtp.getString('auth.pass') }
        : undefined,
    });
    return new Mailer(transporter, config.getString('productionRequests.email.from'), logger);
  }

  async sendToMany(to: string[], subject: string, text: string) {
    if (to.length === 0) {
      this.logger.warn(`No recipients for "${subject}", skipping email`);
      return;
    }
    await this.transporter.sendMail({ from: this.from, to, subject, text });
    this.logger.info(`Emailed "${subject}" to ${to.length} recipient(s)`);
  }
}
4. Resolving recipients from the catalog (src/notifications/recipients.ts)
This walks: API entity → its group annotations → each group's members → each member's email.

ts
import { AuthService } from '@backstage/backend-plugin-api';
import { CatalogService } from '@backstage/plugin-catalog-node';

const GROUP_ANNOTATIONS = [
  'production-requests/api-team',
  'production-requests/manager-approver-group',
  'production-requests/ops-group',
  'production-requests/qa-signoff-group',
];

export async function resolveServiceRecipients(opts: {
  catalog: CatalogService;
  auth: AuthService;
  apiRef: string;
}): Promise<string[]> {
  const { catalog, auth, apiRef } = opts;
  const credentials = await auth.getOwnServiceCredentials(); // service token -> avoids 401

  const api = await catalog.getEntityByRef(apiRef, { credentials });
  if (!api) return [];

  const groupRefs = GROUP_ANNOTATIONS
    .map(a => api.metadata.annotations?.[a])
    .filter((v): v is string => Boolean(v));
  if (groupRefs.length === 0) return [];

  // each Group entity has computed relations; 'hasMember' points at its users
  const groups = await catalog.getEntitiesByRefs({ entityRefs: groupRefs }, { credentials });
  const memberRefs = new Set<string>();
  for (const g of groups.items) {
    for (const rel of g?.relations ?? []) {
      if (rel.type === 'hasMember') memberRefs.add(rel.targetRef);
    }
  }
  if (memberRefs.size === 0) return [];

  const users = await catalog.getEntitiesByRefs({ entityRefs: [...memberRefs] }, { credentials });
  const emails = users.items
    .map(u => (u?.spec as any)?.profile?.email as string | undefined)
    .filter((e): e is string => Boolean(e));

  return [...new Set(emails)]; // dedupe — a user in two groups shouldn't get two mails
}
This is exactly where the naming fixes from turn one matter: if a group annotation points at group:default/mlops-team but the actual Group entity is named Mlops Team, getEntitiesByRefs returns undefined for it and those members silently drop out. So if an email goes to fewer people than expected, check that the annotation refs match real entity names.

5. Tie them together (src/notifications/Notifier.ts)
ts
import { AuthService } from '@backstage/backend-plugin-api';
import { CatalogService } from '@backstage/plugin-catalog-node';
import { Mailer } from './Mailer';
import { resolveServiceRecipients } from './recipients';

export class Notifier {
  constructor(
    private readonly mailer: Mailer,
    private readonly catalog: CatalogService,
    private readonly auth: AuthService,
  ) {}

  async notify(apiRef: string, subject: string, text: string) {
    const recipients = await resolveServiceRecipients({ catalog: this.catalog, auth: this.auth, apiRef });
    await this.mailer.sendToMany(recipients, subject, text);
  }
}
