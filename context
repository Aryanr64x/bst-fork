  const projectPath = GitLabClient.projectPathFromMrUrl(prLink);
  if (!projectPath) {
    res.status(400).json({ error: 'Could not parse GitLab project from prLink' });
    return;
  }

  // 2. create the tracking issue FIRST (must succeed; schema requires the fields)
  let issue;
  try {
    issue = await gitlabClient.createIssue(projectPath, {
      title: `[prod-request] ${title}`,
      description:
        `**PR:** ${prLink}\n` +
        `**Branch:** ${branch}\n` +
        `**Change type:** ${changeType}\n` +
        `**Requested by:** ${requestedBy}\n\n` +
        (description ?? ''),
    });
  } catch (e) {
    logger.error(`Issue creation failed: ${e}`);
    res.status(502).json({ error: `Failed to create tracking issue: ${e}` });
    return;
  }

  // 3. now insert the request with the issue info in hand
  try {
    const created = await store.insert({
      apiRef,
      title,
      prLink,
      branch,
      changeType,
      issueId: issue.iid,
      issueLink: issue.url,
      description,
      requestedBy,
    });
    res.status(201).json(created);
  } catch (e) {
    // insert blew up after the issue was created — surface the orphan so it can be cleaned up
    logger.error(`Insert failed after creating issue !${issue.iid}: ${e}`);
    res.status(500).json({
      error: 'Request creation failed after issue was created',
