async getByPrLink(prLink: string) {
  const norm = (s: string) => s.trim().replace(/\/+$/, ''); // tolerate trailing slashes
  const target = norm(prLink);
  const rows = await this.knex('production_requests');
  const row = rows.find((r: any) => norm(r.pr_link) === target);
