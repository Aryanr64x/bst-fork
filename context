7. Fire from the router
Add notifier to the options and call it after each successful write. The key design decision: email is best-effort and must not break the user's action. So we send the HTTP response first, then trigger the email separately and only log if it fails — a dead SMTP server should never turn a successful approval into a 500.

ts
export async function createRouter(opts: {
  logger: LoggerService;
  store: RequestsStore;
  notifier: Notifier;
}) {
  const { store, notifier, logger } = opts;
  // ... router setup, /health, GET /requests unchanged ...

  router.post('/requests', async (req, res) => {
    const { apiRef, title, prLink, description, requestedBy } = req.body;
    if (!apiRef || !title || !prLink || !requestedBy) {
      res.status(400).json({ error: 'apiRef, title, prLink, requestedBy are required' });
      return;
    }
    const created = await store.insert({ apiRef, title, prLink, description, requestedBy });
    res.status(201).json(created);

    notifier
      .notify(
        created.apiRef,
        `New production request: ${created.title}`,
        `${created.requestedBy} raised a request for ${created.apiRef}.\n` +
          `PR: ${created.prLink}\nCurrent status: ${created.status}`,
      )
      .catch(err => logger.error(`Notification failed: ${err}`));
  });

  router.post('/requests/:id/transition', async (req, res) => {
    const { action, actorGroup, actor, comment } = req.body;
    const existing = await store.getById(req.params.id);
    if (!existing) {
      res.status(404).json({ error: 'request not found' });
      return;
    }
    const result = checkTransition(action, existing.status as Status, actorGroup);
    if (!result.ok) {
      res.status(409).json({ error: result.reason });
      return;
    }
    const updated = await store.applyTransition(existing.id, result.to, {
      actor, action, fromStatus: existing.status, comment,
    });
    res.json(updated);

    notifier
      .notify(
        updated.apiRef,
        `Request "${updated.title}" is now ${updated.status}`,
        `${actor} performed ${action}.\nNew status: ${updated.status}`,
      )
      .catch(err => logger.error(`Notification failed: ${err}`));
  });

  return router;
}
Notice notifier.notify(...) is not awaited before the response — we kick it off and attach a .catch. The response goes back immediately; the email sends in the background. That .catch is mandatory, because an unhandled rejected promise will crash the Node process.

